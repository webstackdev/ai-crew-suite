{
  "name": "root",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22.22.2"
  },
  "packageManager": "yarn@4.17.1",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix"
    ],
    "*.{json,md,css,scss}": [
      "prettier --write"
    ]
  },
  "prettier": "@backstage/cli/config/prettier",
  "workspaces": [
    "packages/*",
    "plugins/**/*"
  ],
  "scripts": {
    "clean": "turbo clean",
    "clean:node_modules": "find plugins -name node_modules -type d -exec rm -rf {} +",
    "dev": "turbo start --filter=app --filter=backend --concurrency=10",
    "dev:ci": "concurrently \"http-server packages/app/dist -a localhost --port 3000 --gzip --proxy http://localhost:3000?\" \"turbo run start-backend\"",
    "start": "turbo start --filter=app",
    "start-backend": "turbo start-backend --filter=backend",
    "start-backend:ci": "yarn workspace backend backstage-cli package build && yarn workspace backend node . --config ../../app-config.yaml --config ../../app-config.production.yaml",
    "start:ci": "concurrently \"yarn start\" \"yarn start-backend:ci\"",
    "build": "yarn tsc && turbo build",
    "build-image": "yarn workspace backend build-image",
    "lint": "turbo lint",
    "lint:changed": "turbo lint --filter=[HEAD~1]",
    "typecheck": "turbo typecheck",
    "typecheck:full": "turbo typecheck --force",
    "test": "turbo test",
    "test:watch": "turbo test --watch --concurrency=1",
    "create-plugin": "backstage-cli new --category plugin --scope @webstackbuilders",
    "new": "backstage-cli new --scope @webstackbuilders",
    "prepare": "husky",
    "release": "changeset version && yarn prettier --write \"{packages,plugins}/*/{package.json,CHANGELOG.md}\" && yarn install",
    "install:clean": "yarn install",
    "install:root": "yarn add -D",
    "install:app": "yarn workspace app add",
    "install:nested": "yarn workspaces foreach -A exec yarn add",
    "upgrade:core": "yarn backstage-cli versions:bump --release main",
    "upgrade:third-party": "yarn up"
  },
  "devDependencies": {
    "@backstage/cli": "backstage:^",
    "@backstage/cli-defaults": "backstage:^",
    "@backstage/cli-module-new": "backstage:^",
    "@backstage/config": "backstage:^",
    "@backstage/eslint-plugin": "backstage:^",
    "@changesets/cli": "^2.31.0",
    "@jest/environment-jsdom-abstract": "^30.4.1",
    "@playwright/test": "^1.61.1",
    "@spotify/eslint-config-base": "^15.0.0",
    "@spotify/eslint-config-react": "^15.0.0",
    "@spotify/eslint-config-typescript": "^15.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.16.0",
    "@vitest/coverage-v8": "^4.1.10",
    "concurrently": "^10.0.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-deprecation": "^3.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-notice": "^1.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "i18next": "26.3.6",
    "jest": "^30.4.2",
    "jsdom": "^27.4.0",
    "lint-staged": "^17.0.8",
    "node-gyp": "^13.0.1",
    "prettier": "^3.9.5",
    "prop-types": "^15.8.1",
    "turbo": "^2.10.5",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10",
    "whatwg-fetch": "^3.6.20"
  },
  "resolutions": {
    "@types/node": "^26.1.1",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "typescript": "5.9.3"
  }
}
