{
  "name": "root",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22.22.2"
  },
  "packageManager": "yarn@4.17.1",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix"
    ],
    "*.{json,md,css,scss}": [
      "prettier --write"
    ]
  },
  "prettier": "@backstage/cli/config/prettier",
  "workspaces": [
    "packages/*",
    "plugins/**/*"
  ],
  "scripts": {
    "dev": "concurrently \"yarn start\" \"yarn start-backend\"",
    "dev:ci": "concurrently \"http-server packages/app/dist -a localhost --port 3000 --gzip --proxy http://localhost:3000?\" \"yarn start-backend\"",
    "start": "yarn workspace app start",
    "start-backend": "yarn workspace backend start",
    "start-backend:ci": "yarn workspace backend backstage-cli package build && node packages/backend",
    "start:ci": "concurrently \"yarn start\" \"yarn start-backend:ci\"",
    "build": "backstage-cli repo build --all",
    "build-image": "yarn workspace backend build-image",
    "install:clean": "rm -f .yarn/install-state.gz && yarn install",
    "install:root": "yarn workspace root add -D",
    "tsc": "tsc --build",
    "tsc:full": "tsc --build --force",
    "clean": "backstage-cli repo clean",
    "test": "vitest run --config=test/vitest.config.ts",
    "test:watch": "vitest --config=test/vitest.config.ts",
    "lint": "backstage-cli repo lint --since origin/main",
    "create-plugin": "backstage-cli new --category plugin --scope roadiehq",
    "new": "backstage-cli new --scope roadiehq",
    "release": "changeset version && yarn prettier --write \"{packages,plugins}/*/{package.json,CHANGELOG.md}\" && yarn install",
    "prepare": "husky"
  },
  "devDependencies": {
    "@backstage/cli": "backstage:^",
    "@changesets/cli": "^2.31.0",
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.61.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "concurrently": "^10.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-jest": "^29.15.4",
    "eslint-plugin-notice": "^1.0.0",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "jest": "^30.0.0",
    "jsdom": "^27.1.0",
    "lint-staged": "^17.0.8",
    "node-gyp": "^13.0.1",
    "prettier": "^3.9.5",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  },
  "resolutions": {
    "@types/node": "^26.1.1",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "typescript": "5.9.3"
  }
}
