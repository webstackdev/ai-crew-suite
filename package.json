{
  "name": "root",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22.22.2"
  },
  "packageManager": "yarn@4.17.1",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix"
    ],
    "*.{json,md,css,scss}": [
      "prettier --write"
    ]
  },
  "prettier": "@backstage/cli/config/prettier",
  "workspaces": [
    "packages/*",
    "plugins/**/*"
  ],
  "scripts": {
    "dev": "turbo start --filter=app --filter=backend --concurrency=10",
    "dev:ci": "concurrently \"http-server packages/app/dist -a localhost --port 3000 --gzip --proxy http://localhost:3000?\" \"turbo start-backend\"",
    "start": "yarn workspace app start",
    "start-backend": "yarn workspace backend start",
    "start-backend:ci": "yarn workspace backend backstage-cli package build && yarn workspace backend node .",
    "start:ci": "concurrently \"yarn start\" \"yarn start-backend:ci\"",
    "build": "yarn tsc && turbo build",
    "build-image": "yarn workspace backend build-image",
    "install:clean": "yarn install",
    "install:root": "yarn add -D",
    "tsc": "tsc --build",
    "tsc:full": "tsc --build --force",
    "clean": "backstage-cli repo clean",
    "test": "vitest run --config=test/vitest.config.ts",
    "test:watch": "vitest --config=test/vitest.config.ts",
    "lint": "eslint .",
    "lint:changed": "yarn lint",
    "create-plugin": "backstage-cli new --category plugin --scope @webstackbuilders",
    "new": "backstage-cli new --scope @webstackbuilders",
    "release": "changeset version && yarn prettier --write \"{packages,plugins}/*/{package.json,CHANGELOG.md}\" && yarn install",
    "prepare": "husky"
  },
  "devDependencies": {
    "@backstage/cli": "backstage:^",
    "@backstage/cli-defaults": "backstage:^",
    "@backstage/config": "backstage:^",
    "@backstage/eslint-plugin": "^0.3.1",
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.61.1",
    "@spotify/eslint-config-base": "^15.0.0",
    "@spotify/eslint-config-react": "^15.0.0",
    "@spotify/eslint-config-typescript": "^15.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.16.0",
    "@vitest/coverage-v8": "^4.1.10",
    "concurrently": "^10.0.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-deprecation": "^3.0.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest": "^29.15.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-notice": "^1.0.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "i18next": "^22.5.1",
    "jest": "^30.0.0",
    "jsdom": "^27.1.0",
    "lint-staged": "^17.0.8",
    "node-gyp": "^13.0.1",
    "prettier": "^3.9.5",
    "prop-types": "^15.8.1",
    "turbo": "^2.10.4",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10",
    "whatwg-fetch": "^3.6.20"
  },
  "resolutions": {
    "@types/node": "^26.1.1",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "typescript": "5.9.3"
  }
}
