{
  "$schema": "https://schemastore.org",
  "compilerOptions": {
    "composite": true,
    "esModuleInterop": true,
    "incremental": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022"
  },
  "files": [],
  "include": [],
  "references": [
    // 1. Core Platform Packages
    { "path": "./packages/app" },
    { "path": "./packages/backend" },

    // 2. Frontend Plugins
    { "path": "./plugins/frontend/plugin-ai-crew-suite" },

    // 3. Backend Core & Nodes
    { "path": "./plugins/backend/plugin-ai-core-backend" },
    { "path": "./plugins/backend/plugin-ai-core-node" },

    // 4. Storage & Vector Connectors
    { "path": "./plugins/backend/plugin-ai-core-backend-module-pgvector" },

    // 5. Embeddings Ecosystem
    { "path": "./plugins/backend/plugin-ai-core-backend-module-aws" },
    { "path": "./plugins/backend/plugin-ai-core-backend-module-openai" },

    // 6. Engine Capabilities
    {
      "path": "./plugins/backend/plugin-ai-core-backend-module-retrieval-augmenter"
    },

    // 7. Test Harness
    { "path": "./test" }
  ]
}
