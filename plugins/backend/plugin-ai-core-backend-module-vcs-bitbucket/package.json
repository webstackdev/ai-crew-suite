{
  "name": "@webstackbuilders/plugin-ai-core-backend-module-vcs-bitbucket",
  "description": "The BitBucket extension for the VCS interface backend module for the ai-core plugin.",
  "version": "0.0.1",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "license": "Apache-2.0",
  "keywords": [
    "backstage",
    "backstage-plugin-module",
    "backend",
    "webstack-builders",
    "ai-crew-suite",
    "ai-core",
    "vcs",
    "Bitbucket",
    "git"
  ],
  "publishConfig": {
    "access": "public",
    "main": "dist/index.cjs.js",
    "types": "dist/index.d.ts"
  },
  "backstage": {
    "role": "backend-plugin-module",
    "pluginId": "ai-core",
    "pluginPackage": [
      "@webstackbuilders/plugin-ai-core-backend"
    ]
  },
  "bugs": {
    "url": "https://github.com/webstackdev/ai-crew-suite/issues",
    "email": "support@webstackbuilders.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/webstackdev/ai-crew-suite",
    "directory": "plugins/backend/ai-core-backend-module-vcs-bitbucket"
  },
  "files": [
    "dist",
    "config.d.ts"
  ],
  "configSchema": "config.d.ts",
  "scripts": {
    "start": "backstage-cli package start",
    "build": "yarn --cwd ../../.. tsc -b plugins/backend/plugin-ai-core-backend-module-vcs-bitbucket/tsconfig.json --emitDeclarationOnly && backstage-cli package build",
    "clean": "backstage-cli package clean",
    "prepack": "backstage-cli package prepack",
    "postpack": "backstage-cli package postpack",
    "typecheck": "tsc --noEmit",
    "lint": "backstage-cli package lint --format stylish",
    "test": "vitest run src --exclude 'dist-types/**' --passWithNoTests"
  },
  "dependencies": {
    "@backstage/backend-plugin-api": "backstage:^",
    "@backstage/integration": "backstage:^",
    "@webstackbuilders/plugin-ai-core-backend-module-vcs": "workspace:*",
    "@webstackbuilders/plugin-ai-core-node": "workspace:*"
  },
  "devDependencies": {
    "@backstage/cli": "backstage:^",
    "vitest": "^4.1.10"
  }
}
