{
  "name": "@webstackbuilders/plugin-ai-core-node",
  "version": "0.0.1",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "license": "Apache-2.0",
  "description": "Core extension point registry for the AI Crew Suite platform.",
  "keywords": [
    "backstage",
    "backstage-plugin",
    "backend",
    "webstack-builders",
    "ai-crew-suite",
    "ai-orchestration",
    "langgraph",
    "multi-agent",
    "rag",
    "extension-points"
  ],
  "publishConfig": {
    "access": "public",
    "main": "dist/index.cjs.js",
    "types": "dist/index.d.ts"
  },
  "backstage": {
    "role": "node-library",
    "pluginId": "ai-core",
    "pluginPackage": [
      "@webstackbuilders/plugin-ai-core-backend"
    ]
  },
  "bugs": {
    "url": "https://github.com/webstackdev/ai-crew-suite/issues",
    "email": "support@webstackbuilders.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/webstackdev/ai-crew-suite",
    "directory": "packages/plugin-ai-core-node"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "backstage-cli package start",
    "build": "yarn --cwd ../../.. tsc -b plugins/backend/plugin-ai-core-node/tsconfig.json --emitDeclarationOnly && backstage-cli package build",
    "clean": "backstage-cli package clean",
    "prepack": "backstage-cli package prepack",
    "postpack": "backstage-cli package postpack",
    "typecheck": "tsc --noEmit",
    "lint": "backstage-cli package lint --format stylish",
    "test": "vitest run src --exclude 'dist-types/**' --passWithNoTests --config ../../../test/vitest.config.ts"
  },
  "dependencies": {
    "@backstage/backend-plugin-api": "backstage:^",
    "@backstage/integration": "backstage:^",
    "@langchain/core": "^1.2.3",
    "i18next": "26.3.6",
    "vitest": "^4.1.10"
  },
  "devDependencies": {
    "@backstage/cli": "backstage:^"
  }
}
