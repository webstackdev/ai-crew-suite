{
  "name": "@webstackbuilders/plugin-ai-core-backend-module-openai",
  "description": "The OpenAI backend module for the @webstackbuilders/plugin-ai-core plugin.",
  "version": "0.0.1",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "license": "Apache-2.0",
  "keywords": [
    "backstage",
    "backstage-plugin-module",
    "backend",
    "webstack-builders",
    "ai-crew-suite",
    "ai-core",
    "openai",
    "embeddings",
    "vector-embeddings",
    "rag"
  ],
  "publishConfig": {
    "access": "public",
    "main": "dist/index.cjs.js",
    "types": "dist/index.d.ts"
  },
  "backstage": {
    "role": "backend-plugin-module",
    "pluginId": "ai-core",
    "pluginPackage": [
      "@webstackbuilders/plugin-ai-core-backend"
    ]
  },
  "bugs": {
    "url": "https://github.com/webstackdev/ai-crew-suite",
    "email": "support@webstackbuilders.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/webstackdev/ai-crew-suite",
    "directory": "packages/plugin-ai-core-backend-module-openai"
  },
  "files": [
    "dist",
    "config.d.ts"
  ],
  "configSchema": "config.d.ts",
  "scripts": {
    "start": "backstage-cli package start",
    "build": "yarn --cwd ../../.. tsc -b plugins/backend/plugin-ai-core-backend-module-openai/tsconfig.json --emitDeclarationOnly && backstage-cli package build",
    "clean": "backstage-cli package clean",
    "prepack": "backstage-cli package prepack",
    "postpack": "backstage-cli package postpack",
    "typecheck": "tsc --noEmit",
    "lint": "backstage-cli package lint --format stylish",
    "test": "vitest run src --exclude 'dist-types/**' --passWithNoTests"
  },
  "dependencies": {
    "@backstage/backend-common": "^0.25.0",
    "@backstage/backend-plugin-api": "backstage:^",
    "@backstage/catalog-client": "backstage:^",
    "@backstage/config": "backstage:^",
    "@langchain/core": "^1.2.3",
    "@langchain/openai": "^1.5.5",
    "@webstackbuilders/plugin-ai-core-backend-module-pgvector": "workspace:^",
    "@webstackbuilders/plugin-ai-core-backend-module-retrieval-augmenter": "workspace:^",
    "@webstackbuilders/plugin-ai-core-node": "workspace:^",
    "i18next": "26.3.6",
    "vitest": "^4.1.10"
  },
  "devDependencies": {
    "@backstage/cli": "backstage:^"
  }
}
