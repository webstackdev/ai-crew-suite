{
  "name": "@webstackbuilders/plugin-ai-core-backend",
  "version": "0.0.1",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "license": "Apache-2.0",
  "keywords": [
    "backstage",
    "plugin",
    "rag-ai",
    "backend"
  ],
  "publishConfig": {
    "access": "public",
    "main": "dist/index.cjs.js",
    "types": "dist/index.d.ts"
  },
  "backstage": {
    "role": "backend-plugin",
    "pluginId": "ai-core",
    "pluginPackages": [
      "@webstackbuilders/plugin-ai-core-backend"
    ]
  },
  "bugs": {
    "url": "https://github.com/webstack-builders/ai-crew-suite/issues",
    "email": "support@webstackbuilders.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com",
    "directory": "packages/rag-ai-backend"
  },
  "files": [
    "dist",
    "config.d.ts"
  ],
  "configSchema": "config.d.ts",
  "scripts": {
    "start": "backstage-cli package start",
    "build": "backstage-cli package build",
    "clean": "backstage-cli package clean",
    "prepack": "backstage-cli package prepack",
    "postpack": "backstage-cli package postpack",
    "typecheck": "tsc --noEmit",
    "lint": "backstage-cli package lint --format stylish",
    "test": "backstage-cli package test --passWithNoTests"
  },
  "dependencies": {
    "@backstage/backend-common": "^0.25.0",
    "@backstage/backend-defaults": "backstage:^",
    "@backstage/backend-plugin-api": "backstage:^",
    "@backstage/config": "backstage:^",
    "@langchain/core": "^1.2.2",
    "@opentelemetry/api": "^1.9.1",
    "@types/express": "4.17.25",
    "@webstackbuilders/plugin-ai-core-node": "workspace:^",
    "@webstackbuilders/plugin-ai-storage-pgvector-node": "workspace:^",
    "express": "^4.22.2",
    "express-promise-router": "^4.1.1",
    "i18next": "26.3.6",
    "lodash": "^4.18.1"
  },
  "devDependencies": {
    "@backstage/cli": "backstage:^",
    "@types/compression": "^1.8.1",
    "@types/lodash": "^4.17.24"
  }
}
