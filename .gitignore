# ==========================================
# 1. System & OS Artifacts
# ==========================================
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Log.txt
*.sublime-project
*.sublime-workspace
.idea/
.project
.classpath
.settings/

# ==========================================
# 2. Local Configuration & Environment Files
# ==========================================

.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.local.yaml
app-config.local.yaml

# ==========================================
# 3. Build Outputs & Compiled Code
# ==========================================

# Bundled production builds (local to packages/plugins)
dist/

# Local type declaration outputs generated by tsc --build
dist-types/

# TypeScript Project References cache files tracking incremental builds
*.tsbuildinfo

# General cache directories
.command-cache/
artifacts/
.turbo/

# ==========================================
# 4. Yarn 4 Plug'n'Play (PnP) Specifics
# ==========================================

node_modules/

# Ignore the transient path installation state cache file
.yarn/install-state.gz

# Standard Install (Keeps Git history lightweight)
# This ignores the heavy zip archive cache, forcing developers to run `yarn install` on clone.
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml

# NEVER ignore these critical Yarn orchestration and development files
!.yarn/patches/
!.yarn/plugins/
!.yarn/releases/
!.yarn/sdks/

# ==========================================
# 5. Testing & Verification Artifacts
# ==========================================

.pnp.*
.eslintcache
.stylelintcache
.prettiercache
coverage/
cypress/videos/
cypress/screenshots/
playwright-report/
test-results/
